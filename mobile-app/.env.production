# Render now — phone (any wifi) and desktop need the same backend to see
# each other's scans. Local backend/DB is dev-only sandbox from here on.
VITE_API_URL=https://vinylscan-api-nnlv.onrender.com
# DEV_TOKEN removed: it was signed for the local backend's SECRET_KEY — Render
# would reject it, and the dev-bypass in App.tsx overwrites any real session
# token on every launch, so a stale one here would lock you out of login.
