# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost/vinylscan

# Auth
SECRET_KEY=your-secret-key-min-32-chars-change-this
ENCRYPTION_KEY=your-32-byte-encryption-key-change-this

# Discogs OAuth
DISCOGS_CONSUMER_KEY=your_discogs_consumer_key
DISCOGS_CONSUMER_SECRET=your_discogs_consumer_secret

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SMALL=price_...
STRIPE_PRICE_MEDIUM=price_...
STRIPE_PRICE_LARGE=price_...

# App
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
DEV_MODE=false

# Image storage — Cloudflare R2 (production)
# Leave empty to use local disk storage (dev only; images lost on restart)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vinylscan-images
R2_PUBLIC_URL=https://your-r2-domain.com

# Local dev fallback (used when R2 vars are empty)
IMAGES_DIR=/tmp/vinylscan_images
